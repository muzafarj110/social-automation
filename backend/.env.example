# Copy to .env and fill in real values. Safe to commit (no secrets).

# --- AI Models Hub ---
HUB_BASE_URL=https://ai-marketing-hub-production-fccb.up.railway.app
HUB_API_KEY=

# --- Zernio (LinkedIn) ---
ZERNIO_BASE_URL=https://zernio.com/api/v1
ZERNIO_API_KEY=

# --- App / Auth ---
# Generate a strong one with:  python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# NOTE: rotating this invalidates all active sessions AND any per-user Hub keys
# encrypted at rest (Fernet key is derived from it) — users must re-enter them.
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database (Railway Postgres) ---
DATABASE_URL=

# --- Redis (Railway) ---
REDIS_URL=redis://localhost:6379/0
